                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"name\": \"Small (8 inch)\",\n    \"priceAdjustment\": 0,\n    \"isDefault\": true,\n    \"sortOrder\": 1\n  },\n  {\n    \"name\": \"Medium (12 inch)\",\n    \"priceAdjustment\": 3.00,\n    \"isDefault\": false,\n    \"sortOrder\": 2\n  },\n  {\n    \"name\": \"Large (16 inch)\",\n    \"priceAdjustment\": 5.00,\n    \"isDefault\": false,\n    \"sortOrder\": 3\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups/{{modifierGroupId}}/options",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups", "{{modifierGroupId}}", "options"]
            },
            "description": "Bulk creates size options"
          },
          "response": []
