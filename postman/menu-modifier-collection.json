{
  "info": {
    "name": "RestroFly POS - Menu & Modifier System",
    "description": "Complete API collection for RestroFly POS Menu and Modifier management system with hybrid inheritance",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "modifierGroupId",
      "value": "",
      "type": "string"
    },
    {
      "key": "modifierOptionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "menuItemId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set('authToken', jsonData.token);",
                  "        console.log('Auth token saved:', jsonData.token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restrofly.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "sign-in"]
            },
            "description": "Login as admin to get authentication token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. Modifier Groups",
      "item": [
        {
          "name": "Get All Modifier Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups"]
            },
            "description": "Retrieves all modifier groups with their usage statistics"
          },
          "response": []
        },
        {
          "name": "Create Modifier Group - Choose Size",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('modifierGroupId', jsonData.data.id);",
                  "    console.log('Modifier Group ID saved:', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Choose Size\",\n  \"description\": \"Select your preferred size\",\n  \"isRequired\": true,\n  \"allowMultiple\": false,\n  \"minSelection\": 1,\n  \"maxSelection\": 1,\n  \"sortOrder\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups"]
            },
            "description": "Creates a new modifier group for size selection"
          },
          "response": []
        },
        {
          "name": "Create Modifier Group - Extra Toppings",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Extra Toppings\",\n  \"description\": \"Add extra toppings (up to 5)\",\n  \"isRequired\": false,\n  \"allowMultiple\": true,\n  \"minSelection\": 0,\n  \"maxSelection\": 5,\n  \"sortOrder\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups"]
            }
          },
          "response": []
        },
        {
          "name": "Create Modifier Group - Spice Level",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spice Level\",\n  \"description\": \"Choose your heat preference\",\n  \"isRequired\": false,\n  \"allowMultiple\": false,\n  \"minSelection\": 0,\n  \"maxSelection\": 1,\n  \"sortOrder\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups"]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Modifier Group",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups/{{modifierGroupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups", "{{modifierGroupId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Modifier Group",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Choose Your Size\",\n  \"description\": \"Pick the perfect size for you\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups/{{modifierGroupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups", "{{modifierGroupId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Modifier Group",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups/{{modifierGroupId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups", "{{modifierGroupId}}"]
            },
            "description": "Cannot delete if assigned to any category or menu item"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Modifier Options",
      "item": [
        {
          "name": "Get Options for Group",
          "request": {
            "method": "GET",
            "header": [],
