        {
          "name": "Assign Modifiers to Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"modifierGroupIds\": [1, 2]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories/{{categoryId}}/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "categories", "{{categoryId}}", "modifier-groups"]
            },
            "description": "Sets default modifiers for all items in this category (replaces existing)"
          },
          "response": []
        },
        {
          "name": "Remove Category Modifiers",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories/{{categoryId}}/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "categories", "{{categoryId}}", "modifier-groups"]
            }
          },
          "response": []
        }
      ]
