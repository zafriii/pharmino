              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Large (18 inch)\",\n  \"priceAdjustment\": 6.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-options/{{modifierOptionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-options", "{{modifierOptionId}}"]
            }
          },
          "response": []
