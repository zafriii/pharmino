              "raw": "{\n  \"name\": \"Extra Large\",\n  \"priceAdjustment\": 7.00,\n  \"isDefault\": false,\n  \"isAvailable\": true,\n  \"sortOrder\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/modifier-groups/{{modifierGroupId}}/options",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "modifier-groups", "{{modifierGroupId}}", "options"]
            }
          },
          "response": []
