    {
      "name": "3. Categories with Modifiers",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "categories"]
            }
          },
          "response": []
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('categoryId', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza\",\n  \"imageUrl\": \"https://example.com/pizza.jpg\",\n  \"sortOrder\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "categories"]
            }
          },
          "response": []
        },
        {
          "name": "Get Category Modifier Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories/{{categoryId}}/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "categories", "{{categoryId}}", "modifier-groups"]
            },
            "description": "Gets default modifiers for this category"
          },
          "response": []
