            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/menu-items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "menu-items", "{{menuItemId}}"]
            },
            "description": "Public endpoint - Returns item with merged modifiers (category defaults + custom)"
          },
          "response": []
        }
      ]
    },
