    {
      "name": "4. Menu Items with Modifiers",
      "item": [
        {
          "name": "Get All Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "pizza",
                  "disabled": true
                },
                {
                  "key": "categoryId",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "isAvailable",
                  "value": "true",
                  "disabled": true
                },
                {
                  "key": "includeArchived",
                  "value": "false",
                  "disabled": true
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Item (Inherits Category Defaults)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('menuItemId', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Margherita Pizza\",\n  \"categoryId\": {{categoryId}},\n  \"basePrice\": 10.00,\n  \"serviceCharge\": 0,\n  \"description\": \"Classic Italian pizza with fresh mozzarella\",\n  \"imageUrl\": \"https://example.com/margherita.jpg\",\n  \"isAvailable\": true,\n  \"sortOrder\": 1,\n  \"usesCategoryDefaults\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items"]
            },
            "description": "Creates item that inherits category modifiers"
          },
          "response": []
        },
        {
          "name": "Create Item (Custom Modifiers)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Personal Flatbread\",\n  \"categoryId\": {{categoryId}},\n  \"basePrice\": 7.00,\n  \"serviceCharge\": 0,\n  \"description\": \"Single-serving flatbread (no size options)\",\n  \"isAvailable\": true,\n  \"sortOrder\": 5,\n  \"usesCategoryDefaults\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items"]
            },
            "description": "Creates item that does NOT inherit category defaults"
          },
          "response": []
        },
        {
          "name": "Get Item Modifier Groups",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items/{{menuItemId}}/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items", "{{menuItemId}}", "modifier-groups"]
            },
            "description": "Gets custom modifiers for this item (excludes category defaults)"
          },
          "response": []
        },
        {
          "name": "Assign Custom Modifiers to Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"modifierGroupIds\": [3]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items/{{menuItemId}}/modifier-groups",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items", "{{menuItemId}}", "modifier-groups"]
            },
            "description": "Adds custom modifiers (extends category defaults if usesCategoryDefaults=true)"
          },
          "response": []
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"basePrice\": 12.00,\n  \"usesCategoryDefaults\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items", "{{menuItemId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Archive Menu Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admin/menu-items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "menu-items", "{{menuItemId}}"]
            },
            "description": "Soft delete (sets isArchived=true)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Public Menu (Customer-Facing)",
      "item": [
        {
          "name": "Get Menu Item with Modifiers",
          "request": {
            "auth": {
              "type": "noauth"
