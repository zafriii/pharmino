        {
          "name": "Create Single Option",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('modifierOptionId', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
