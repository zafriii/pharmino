              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"summary\": {\n      \"totalRevenue\": \"45000.00\",\n      \"totalExpenses\": \"12000.00\",\n      \"totalPayroll\": \"8000.00\",\n      \"totalRefunds\": \"500.00\",\n      \"netRevenue\": \"44500.00\",\n      \"netProfit\": \"24500.00\",\n      \"profitMargin\": \"55.06\",\n      \"orderCount\": 350,\n      \"averageOrderValue\": \"128.57\"\n    },\n    \"timeSeries\": [\n      {\n        \"date\": \"2025-11-01\",\n        \"revenue\": \"1500.00\",\n        \"expenses\": \"800.00\",\n        \"profit\": \"700.00\"\n      },\n      {\n        \"date\": \"2025-11-02\",\n        \"revenue\": \"1800.00\",\n        \"expenses\": \"750.00\",\n        \"profit\": \"1050.00\"\n      }\n    ],\n    \"metadata\": {\n      \"startDate\": \"2025-11-01\",\n      \"endDate\": \"2025-11-27\",\n      \"groupBy\": \"daily\"\n    }\n  }\n}"
