        {
          "name": "1. Profit & Loss Analytics (Daily)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/analytics/profit-loss?startDate={{startDate}}&endDate={{endDate}}&groupBy=daily",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "analytics", "profit-loss"],
              "query": [
                {
                  "key": "startDate",
                  "value": "{{startDate}}",
                  "description": "Start date in YYYY-MM-DD format"
                },
                {
                  "key": "endDate",
                  "value": "{{endDate}}",
                  "description": "End date in YYYY-MM-DD format"
                },
                {
                  "key": "groupBy",
                  "value": "daily",
                  "description": "Grouping: daily, weekly, or monthly"
                }
              ]
            },
            "description": "Get comprehensive profit and loss analysis with time-series data grouped by day.\n\n**Features:**\n- Total revenue from PAID orders\n- Refunds deducted from net revenue\n- Operational expenses and payroll costs\n- Profit margins and KPIs\n- Daily time-series data for charts\n\n**Auth Required:** Admin only"
          },
