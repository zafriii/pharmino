          "// 1. Login through the auth endpoint first",
          "// 2. Postman will automatically save the session cookie",
          "// 3. All subsequent requests will include the cookie",
          "",
          "// You can also manually set the cookie in Postman:",
          "// Cookies → Add Cookie → better-auth.session_token=<your_token>"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test scripts",
          "pm.test(\"Response time is less than 5000ms\", function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "// Check for JSON response (except PDF export)",
          "if (pm.response.headers.get('Content-Type') === 'application/json') {",
          "    pm.test(\"Response has JSON body\", function () {",
          "        pm.response.to.have.jsonBody();",
          "    });",
          "",
          "    pm.test(\"Response has success field\", function () {",
          "        pm.expect(pm.response.json()).to.have.property('success');",
          "    });",
          "}"
        ]
      }
    }
  ]
